---
import { profile } from "../data/profile";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <p>&copy; {year} {profile.name}. Built with Astro and GitHub Pages.</p>
    <nav class="footer-links" aria-label="Contact and profiles">
      <a href={`mailto:${profile.email}`}>CIMNE email</a>
      <a href={`mailto:${profile.secondaryEmail}`}>Personal email</a>
      <a href={profile.links.github}>GitHub</a>
      <a href={profile.links.orcid} target="_blank" rel="noreferrer">ORCID</a>
      <a href={profile.links.cv} target="_blank" rel="noreferrer">CV PDF</a>
    </nav>
  </div>
</footer>
