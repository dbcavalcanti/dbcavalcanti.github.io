---
import BaseLayout from "../components/BaseLayout.astro";
import PublicationList from "../components/PublicationList.astro";
import { publicationGroups } from "../data/publications";
---

<BaseLayout
  title="Research"
  description="My research publications, manuscripts, talks, and conference papers."
>
  <header class="page-header">
    <p class="eyebrow">Research</p>
    <h1>Publications and research output</h1>
    <p>
      Here is a list of my publications, manuscripts, talks, and conference papers.
    </p>
  </header>

  <PublicationList groups={publicationGroups} />
</BaseLayout>
