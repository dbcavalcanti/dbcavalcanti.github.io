---
import BaseLayout from "../components/BaseLayout.astro";
import PdfResourceList from "../components/PdfResourceList.astro";
import { notes } from "../data/notes";

const noteResources = notes.map((note) => ({
  topic: note.topic,
  description: note.description,
  language: note.language,
  date: note.date,
  pdf: note.pdf
}));
---

<BaseLayout
  title="Personal study notes"
  description="Informal study notes I have written while learning and doing research."
>
  <header class="page-header">
    <p class="eyebrow">Notes</p>
    <h1>Personal study notes</h1>
    <p>
      Here I share informal notes I wrote while studying or developing formulations.
      They are working documents, so I may revise them over time.
    </p>
  </header>

  <PdfResourceList resources={noteResources} />
</BaseLayout>
