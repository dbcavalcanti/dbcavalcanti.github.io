---
import BaseLayout from "../components/BaseLayout.astro";
import SoftwareCard from "../components/SoftwareCard.astro";
import { software } from "../data/software";
---

<BaseLayout
  title="Software"
  description="Scientific software and computational mechanics projects I have built or contributed to."
>
  <header class="page-header">
    <p class="eyebrow">Software</p>
    <h1>Scientific software</h1>
    <p>
      Here are the research codes and software projects I have built or contributed
      to, with a short note about my role and where to find them.
    </p>
  </header>

  <div class="card-grid">
    {software.map((entry) => <SoftwareCard entry={entry} />)}
  </div>
</BaseLayout>
